---

<section id="contact" class="relative z-10 py-24 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="font-mono text-3xl md:text-4xl font-bold mb-2 scroll-fade">
      <span class="text-[var(--color-accent-purple)]">#</span> Contact
    </h2>
    <div class="w-20 h-0.5 bg-[var(--color-accent-purple)] mx-auto mb-12 scroll-fade"></div>

    <p class="text-[var(--color-text-secondary)] max-w-lg mx-auto mb-12 scroll-fade">
      有任何合作想法、問題或只是想打個招呼？歡迎隨時聯繫我！
    </p>

    <div class="flex justify-center gap-6 mb-16 scroll-fade">
      {socials.map((social) => (
        <a
          href={social.href}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex flex-col items-center gap-2"
        >
          <div class="w-14 h-14 rounded-lg bg-[var(--color-bg-card)] card-glow flex items-center justify-center group-hover:-translate-y-1 transition-all duration-300">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--color-text-secondary)"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="group-hover:stroke-[var(--color-accent-cyan)] transition-colors"
              set:html={social.icon}
            />
          </div>
          <span class="font-mono text-xs text-[var(--color-text-secondary)] group-hover:text-[var(--color-accent-cyan)] transition-colors">
            {social.name}
          </span>
        </a>
      ))}
    </div>

    <a
      href="mailto:willie@example.com"
      class="inline-block px-8 py-3 border border-[var(--color-accent-cyan)] text-[var(--color-accent-cyan)] font-mono text-sm rounded hover:bg-[var(--color-accent-cyan)] hover:text-[var(--color-bg-primary)] transition-all duration-300 scroll-fade"
    >
      Say Hello
    </a>
  </div>
</section>

<footer class="relative z-10 py-8 px-6 border-t border-[var(--color-border)]">
  <div class="max-w-4xl mx-auto text-center">
    <p class="font-mono text-sm text-[var(--color-text-secondary)]">
      &copy; 2026 Willie. Built with Astro + Three.js
    </p>
  </div>
</footer>
