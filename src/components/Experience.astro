---

<section id="experience" class="relative z-10 py-24 px-6">
  <div class="max-w-4xl mx-auto section-backdrop p-8 md:p-12">
    <h2 class="font-mono text-3xl md:text-4xl font-bold mb-2 scroll-fade">
      <span class="text-[var(--color-accent-cyan)]">#</span> Experience
    </h2>
    <div class="w-20 h-0.5 bg-[var(--color-accent-cyan)] mb-12 scroll-fade"></div>

    <div class="space-y-4">
      {experiences.map((exp) => (
        <div class="flex items-center gap-4 p-4 rounded-lg card-glass card-glow transition-all duration-300 hover:translate-x-2 scroll-fade">
          <span class="text-[var(--color-accent-cyan)] text-lg">&#9654;</span>
          <div>
            <h3 class="font-mono text-base font-semibold text-[var(--color-text-primary)]">
              {exp.title}
            </h3>
            <p class="text-sm text-[var(--color-text-secondary)]">
              {exp.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
