---
import Layout from './Layout.astro';
import BlogNavbar from '../components/BlogNavbar.astro';

interface Props {
  title: string;
  date: string;
}

const { title, date } = Astro.props;
---

<Layout title={`${title} | Willie`}>
  <div class="min-h-screen flex flex-col">
  <BlogNavbar />
  <main class="pt-24 pb-16 px-6 flex-grow">
    <article class="max-w-3xl mx-auto">
      <header class="mb-12">
        <a href="/blog" class="font-mono text-sm text-[var(--color-accent-purple)] hover:text-[var(--color-accent-cyan)] transition-colors mb-4 inline-block">
          &larr; Back to Blog
        </a>
        <h1 class="font-mono text-3xl md:text-4xl font-bold text-[var(--color-text-primary)] mb-3">
          {title}
        </h1>
        <time class="font-mono text-sm text-[var(--color-accent-purple)]">{date}</time>
      </header>

      <div class="prose">
        <slot />
      </div>
    </article>
  </main>

  <footer class="py-8 px-6 border-t border-[var(--color-border)]">
    <div class="max-w-3xl mx-auto text-center">
      <p class="font-mono text-sm text-[var(--color-text-secondary)]">
        &copy; 2026 Willie
      </p>
    </div>
  </footer>
  </div>
</Layout>

<style>
  .prose {
    color: var(--color-text-secondary);
    line-height: 1.8;
    font-size: 1rem;
  }

  .prose :global(h1) {
    font-family: var(--font-mono);
    color: var(--color-text-primary);
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .prose :global(h1)::before {
    content: '# ';
    color: var(--color-accent-cyan);
  }

  .prose :global(h2) {
    font-family: var(--font-mono);
    color: var(--color-text-primary);
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(h2)::before {
    content: '## ';
    color: var(--color-accent-purple);
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose :global(a) {
    color: var(--color-accent-cyan);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(a):hover {
    color: var(--color-accent-purple);
  }

  .prose :global(strong) {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    background: rgba(10, 10, 30, 0.5);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.15em 0.4em;
    font-size: 0.875em;
    color: var(--color-accent-cyan);
  }

  .prose :global(pre) {
    background: rgba(10, 10, 30, 0.6);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .prose :global(pre) :global(code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(ul) {
    list-style: none;
  }

  .prose :global(ul) :global(li)::before {
    content: '▸ ';
    color: var(--color-accent-cyan);
  }

  .prose :global(ol) {
    list-style: decimal;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent-purple);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .prose :global(img) {
    border-radius: 8px;
    margin: 1.5rem 0;
    max-width: 100%;
  }
</style>
